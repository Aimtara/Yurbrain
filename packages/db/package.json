{
  "name": "@yurbrain/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:reset": "tsx src/scripts/reset.ts",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:backfill:profiles": "tsx src/scripts/n5-backfill-profiles.ts",
    "test": "tsx --test src/__tests__/*.test.ts",
    "typecheck": "tsc --noEmit --target ES2022 --module ESNext --moduleResolution Bundler --strict --skipLibCheck --types node src/index.ts",
    "lint": "pnpm typecheck",
    "build": "echo \"@yurbrain/db is source-consumed in the monorepo; no package build artifact is emitted\""
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "drizzle-orm": "^0.44.2",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "@types/node": "^22.15.3"
  }
}
