{
  "name": "yurbrain",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "bootstrap": "pnpm install && pnpm reset && pnpm seed",
    "dev": "pnpm dev:api",
    "dev:all": "turbo run dev --parallel --filter=api --filter=web --filter=mobile",
    "dev:mobile": "pnpm --filter mobile dev",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "reset": "node tooling/scripts/reset-dev-db.mjs",
    "seed": "node tooling/scripts/seed-dev-db.mjs",
    "reseed": "pnpm reset && pnpm seed",
    "test:e2e": "NODE_ENV=test pnpm --filter api exec tsx --test ../../e2e/full-loop.spec.ts",
    "boundary:check": "node scripts/check-boundary-imports.mjs",
    "lint": "turbo lint && pnpm check:boundaries",
    "test": "turbo test",
    "build": "turbo build",
    "check:boundaries": "node scripts/check-boundary-imports.mjs"
  },
  "devDependencies": {
    "turbo": "^2.9.6"
  },
  "packageManager": "pnpm@10.18.3"
}
