# Yurbrain root environment template (no secrets)
# Canonical environment/deployment matrix:
# docs/nhost/environments.md
#
# Copy values into:
# - apps/api/.env
# - apps/web/.env.local
# - apps/mobile/.env
#
# Required by environment:
# - local / preview / staging / production each have distinct Nhost projects/keys.

# -----------------------------------------------------------------------------
# Shared deployment identity
# -----------------------------------------------------------------------------
NHOST_PROJECT_ENV=local # local | preview | staging | production
NHOST_PROJECT_SUBDOMAIN=
NHOST_PROJECT_REGION=

# -----------------------------------------------------------------------------
# API server-only runtime vars (preferred canonical keys)
# -----------------------------------------------------------------------------
NHOST_SUBDOMAIN=
NHOST_REGION=
NHOST_BACKEND_URL=
NHOST_GRAPHQL_URL=
NHOST_AUTH_URL=
NHOST_STORAGE_URL=
NHOST_FUNCTIONS_URL=
NHOST_ANON_KEY=
NHOST_ADMIN_SECRET=
NHOST_JWT_ISSUER=
NHOST_JWT_AUDIENCE=
NHOST_JWKS_URL=
API_ALLOWED_ORIGINS= # comma-separated web/mobile origins

# Optional API auth redirect refs (must match dashboard allowlist)
NHOST_AUTH_REDIRECT_SIGN_IN_URL=
NHOST_AUTH_REDIRECT_SIGN_OUT_URL=
NHOST_AUTH_REDIRECT_SIGN_UP_URL=
NHOST_AUTH_REDIRECT_PASSWORD_RESET_URL=
NHOST_AUTH_REDIRECT_EMAIL_VERIFICATION_URL=

# -----------------------------------------------------------------------------
# Temporary compatibility aliases (deprecated after cutover)
# Keep until all environments run canonical NHOST_* only.
# -----------------------------------------------------------------------------
YURBRAIN_NHOST_SUBDOMAIN=
YURBRAIN_NHOST_REGION=
YURBRAIN_NHOST_BACKEND_URL=
YURBRAIN_NHOST_GRAPHQL_URL=
YURBRAIN_NHOST_AUTH_URL=
YURBRAIN_NHOST_STORAGE_URL=
YURBRAIN_NHOST_FUNCTIONS_URL=
YURBRAIN_NHOST_ANON_KEY=
YURBRAIN_NHOST_ADMIN_SECRET=
YURBRAIN_NHOST_JWT_ISSUER=
YURBRAIN_NHOST_JWT_AUDIENCE=
YURBRAIN_NHOST_JWKS_URL=
YURBRAIN_HASURA_GRAPHQL_URL=
YURBRAIN_HASURA_ADMIN_SECRET=

# -----------------------------------------------------------------------------
# Web public runtime vars (safe for browser bundle)
# -----------------------------------------------------------------------------
YURBRAIN_API_ORIGIN= # Next.js server-side rewrite target for web/api proxying
NEXT_PUBLIC_YURBRAIN_API_URL= # optional explicit browser API base URL when not using same-origin rewrites
NEXT_PUBLIC_NHOST_SUBDOMAIN=
NEXT_PUBLIC_NHOST_REGION=
NEXT_PUBLIC_NHOST_BACKEND_URL=
NEXT_PUBLIC_NHOST_GRAPHQL_URL=
NEXT_PUBLIC_NHOST_AUTH_URL=
NEXT_PUBLIC_NHOST_STORAGE_URL=
NEXT_PUBLIC_NHOST_FUNCTIONS_URL=
NEXT_PUBLIC_NHOST_ANON_KEY=
NEXT_PUBLIC_NHOST_APP_ORIGIN=

NEXT_PUBLIC_NHOST_SIGN_IN_REDIRECT_URL=
NEXT_PUBLIC_NHOST_SIGN_OUT_REDIRECT_URL=
NEXT_PUBLIC_NHOST_PASSWORD_RESET_REDIRECT_URL=
NEXT_PUBLIC_NHOST_EMAIL_VERIFICATION_REDIRECT_URL=
NEXT_PUBLIC_NHOST_SIGN_IN_REDIRECT_PATH=
NEXT_PUBLIC_NHOST_SIGN_OUT_REDIRECT_PATH=
NEXT_PUBLIC_NHOST_PASSWORD_RESET_REDIRECT_PATH=
NEXT_PUBLIC_NHOST_EMAIL_VERIFICATION_REDIRECT_PATH=

# -----------------------------------------------------------------------------
# Mobile public runtime vars (safe for app bundle)
# -----------------------------------------------------------------------------
EXPO_PUBLIC_YURBRAIN_API_URL= # explicit hosted API base URL for staging/native/manual QA
EXPO_PUBLIC_NHOST_SUBDOMAIN=
EXPO_PUBLIC_NHOST_REGION=
EXPO_PUBLIC_NHOST_BACKEND_URL=
EXPO_PUBLIC_NHOST_GRAPHQL_URL=
EXPO_PUBLIC_NHOST_AUTH_URL=
EXPO_PUBLIC_NHOST_STORAGE_URL=
EXPO_PUBLIC_NHOST_FUNCTIONS_URL=
EXPO_PUBLIC_NHOST_ANON_KEY=
EXPO_PUBLIC_NHOST_MOBILE_DEEP_LINK_BASE_URL=
EXPO_PUBLIC_NHOST_SIGN_IN_REDIRECT_URL=
EXPO_PUBLIC_NHOST_SIGN_OUT_REDIRECT_URL=
EXPO_PUBLIC_NHOST_PASSWORD_RESET_REDIRECT_URL=
EXPO_PUBLIC_NHOST_EMAIL_VERIFICATION_REDIRECT_URL=

# -----------------------------------------------------------------------------
# LLM provider (API server-only — optional, deterministic fallback when disabled)
# -----------------------------------------------------------------------------
YURBRAIN_LLM_ENABLED=false
YURBRAIN_LLM_PROVIDER=openai
YURBRAIN_LLM_API_KEY=
YURBRAIN_LLM_BASE_URL=https://api.openai.com/v1
YURBRAIN_LLM_MODEL=gpt-4o-mini
YURBRAIN_LLM_FAST_MODEL=         # defaults to YURBRAIN_LLM_MODEL
YURBRAIN_LLM_REASONING_MODEL=    # defaults to YURBRAIN_LLM_MODEL
YURBRAIN_LLM_TIMEOUT_MS=1800
YURBRAIN_LLM_MAX_OUTPUT_TOKENS=220
YURBRAIN_LLM_TEMPERATURE=0.2

# -----------------------------------------------------------------------------
# Test/local-only helpers (never set in production)
# -----------------------------------------------------------------------------
YURBRAIN_TEST_MODE=
YURBRAIN_ALLOW_TEST_USER_HEADER=
YURBRAIN_TEST_JWT_SECRET=
YURBRAIN_TEST_JWT_ISSUER=
YURBRAIN_TEST_JWT_AUDIENCE=
