# Web public environment template (safe to ship to browser bundles).
#
# Canonical matrix + local/preview/staging/production examples:
# docs/nhost/environments.md
#
# IMPORTANT:
# - Never place server secrets here.
# - NEXT_PUBLIC_* values are visible client-side.

# -----------------------------------------------------------------------------
# Nhost addressing (at least one addressing mode must be configured)
# -----------------------------------------------------------------------------
# Mode A (preferred): explicit backend URL
NEXT_PUBLIC_NHOST_BACKEND_URL=
# Mode B (fallback): subdomain + region
NEXT_PUBLIC_NHOST_SUBDOMAIN=
NEXT_PUBLIC_NHOST_REGION=

# Optional explicit service URLs (otherwise derived from backend URL)
NEXT_PUBLIC_NHOST_GRAPHQL_URL=
NEXT_PUBLIC_NHOST_AUTH_URL=
NEXT_PUBLIC_NHOST_STORAGE_URL=
NEXT_PUBLIC_NHOST_FUNCTIONS_URL=

# Required public anon key
NEXT_PUBLIC_NHOST_ANON_KEY=

# Optional explicit web origin override for redirect composition
NEXT_PUBLIC_NHOST_APP_ORIGIN=

# Optional explicit Yurbrain API base URL for browser fetches when not using same-origin rewrites.
NEXT_PUBLIC_YURBRAIN_API_URL=

# Required for staged/hosted web deploys so Next.js rewrites target the correct API origin.
YURBRAIN_API_ORIGIN=

# -----------------------------------------------------------------------------
# Auth redirect URLs
# -----------------------------------------------------------------------------
# Preferred for preview/staging/production: explicit full URLs.
NEXT_PUBLIC_NHOST_SIGN_IN_REDIRECT_URL=
NEXT_PUBLIC_NHOST_SIGN_OUT_REDIRECT_URL=
NEXT_PUBLIC_NHOST_PASSWORD_RESET_REDIRECT_URL=
NEXT_PUBLIC_NHOST_EMAIL_VERIFICATION_REDIRECT_URL=

# Optional path-based fallback redirects when explicit URLs are unset.
NEXT_PUBLIC_NHOST_SIGN_IN_REDIRECT_PATH=
NEXT_PUBLIC_NHOST_SIGN_OUT_REDIRECT_PATH=
NEXT_PUBLIC_NHOST_PASSWORD_RESET_REDIRECT_PATH=
NEXT_PUBLIC_NHOST_EMAIL_VERIFICATION_REDIRECT_PATH=
