## Canonical environment matrix:
## docs/nhost/environments.md
## Server-only variables in this file must never be exposed to web/mobile bundles.
## Preferred runtime keys are NHOST_*.
## Compatibility keys (YURBRAIN_*) are supported temporarily during cutover.

NHOST_SUBDOMAIN=
NHOST_REGION=
NHOST_BACKEND_URL=
NHOST_GRAPHQL_URL=
NHOST_AUTH_URL=
NHOST_JWKS_URL=
NHOST_JWT_ISSUER=
NHOST_JWT_AUDIENCE=
NHOST_STORAGE_URL=
NHOST_FUNCTIONS_URL=
NHOST_ANON_KEY=
NHOST_ADMIN_SECRET=
NHOST_AUTH_REDIRECT_SIGN_IN_URL=
NHOST_AUTH_REDIRECT_SIGN_OUT_URL=
NHOST_AUTH_REDIRECT_SIGN_UP_URL=
NHOST_AUTH_REDIRECT_PASSWORD_RESET_URL=
NHOST_AUTH_REDIRECT_EMAIL_VERIFICATION_URL=
API_ALLOWED_ORIGINS=

# -----------------------------------------------------------------------------
# Deployment environment (drives CORS strictness, rate limits, identity mode)
# -----------------------------------------------------------------------------
NHOST_PROJECT_ENV=local # local | preview | staging | production

# Optional strict identity enforcement (overrides NHOST_PROJECT_ENV for identity)
# YURBRAIN_IDENTITY_MODE=strict

# -----------------------------------------------------------------------------
# LLM provider (optional — deterministic fallback used when disabled/unconfigured)
# -----------------------------------------------------------------------------
YURBRAIN_LLM_ENABLED=false
YURBRAIN_LLM_PROVIDER=openai
YURBRAIN_LLM_API_KEY=
YURBRAIN_LLM_BASE_URL=https://api.openai.com/v1
YURBRAIN_LLM_MODEL=gpt-4o-mini
YURBRAIN_LLM_FAST_MODEL=         # defaults to YURBRAIN_LLM_MODEL
YURBRAIN_LLM_REASONING_MODEL=    # defaults to YURBRAIN_LLM_MODEL
YURBRAIN_LLM_TIMEOUT_MS=1800
YURBRAIN_LLM_MAX_OUTPUT_TOKENS=220
YURBRAIN_LLM_TEMPERATURE=0.2

# -----------------------------------------------------------------------------
# Rate limiting (optional tuning — sensible defaults built in)
# -----------------------------------------------------------------------------
# YURBRAIN_RATE_LIMIT_DISABLED=false
# YURBRAIN_RATE_LIMIT_WINDOW_MS=60000

# Optional server runtime support keys
PORT=3001
NODE_ENV=development

# Deprecated compatibility aliases.
# These are supported temporarily during the Nhost cutover.
# Prefer NHOST_* above. Remove after local/staging/prod have migrated.
YURBRAIN_NHOST_SUBDOMAIN=
YURBRAIN_NHOST_REGION=
YURBRAIN_NHOST_BACKEND_URL=
YURBRAIN_NHOST_AUTH_URL=
YURBRAIN_NHOST_JWKS_URL=
YURBRAIN_NHOST_JWT_ISSUER=
YURBRAIN_NHOST_JWT_AUDIENCE=
YURBRAIN_NHOST_GRAPHQL_URL=
YURBRAIN_NHOST_STORAGE_URL=
YURBRAIN_NHOST_FUNCTIONS_URL=
YURBRAIN_NHOST_ANON_KEY=
YURBRAIN_NHOST_ADMIN_SECRET=
YURBRAIN_HASURA_GRAPHQL_URL=
YURBRAIN_HASURA_ADMIN_SECRET=
YURBRAIN_HASURA_ROLE=user
