## Canonical environment matrix:
## docs/nhost/environments.md
## Server-only variables in this file must never be exposed to web/mobile bundles.
## Preferred runtime keys are NHOST_*.
## Compatibility keys (YURBRAIN_*) are supported temporarily during cutover.

NHOST_SUBDOMAIN=
NHOST_REGION=
NHOST_BACKEND_URL=
NHOST_GRAPHQL_URL=
NHOST_AUTH_URL=
NHOST_JWKS_URL=
NHOST_JWT_ISSUER=
NHOST_JWT_AUDIENCE=
NHOST_STORAGE_URL=
NHOST_FUNCTIONS_URL=
NHOST_ANON_KEY=
NHOST_ADMIN_SECRET=
NHOST_AUTH_REDIRECT_SIGN_IN_URL=
NHOST_AUTH_REDIRECT_SIGN_OUT_URL=
NHOST_AUTH_REDIRECT_SIGN_UP_URL=
NHOST_AUTH_REDIRECT_PASSWORD_RESET_URL=
NHOST_AUTH_REDIRECT_EMAIL_VERIFICATION_URL=
API_ALLOWED_ORIGINS=

# Optional server runtime support keys
PORT=3001
NODE_ENV=development

# Deprecated compatibility aliases.
# These are supported temporarily during the Nhost cutover.
# Prefer NHOST_* above. Remove after local/staging/prod have migrated.
YURBRAIN_NHOST_SUBDOMAIN=
YURBRAIN_NHOST_REGION=
YURBRAIN_NHOST_BACKEND_URL=
YURBRAIN_NHOST_AUTH_URL=
YURBRAIN_NHOST_JWKS_URL=
YURBRAIN_NHOST_JWT_ISSUER=
YURBRAIN_NHOST_JWT_AUDIENCE=
YURBRAIN_NHOST_GRAPHQL_URL=
YURBRAIN_NHOST_STORAGE_URL=
YURBRAIN_NHOST_FUNCTIONS_URL=
YURBRAIN_NHOST_ANON_KEY=
YURBRAIN_NHOST_ADMIN_SECRET=
YURBRAIN_HASURA_GRAPHQL_URL=
YURBRAIN_HASURA_ADMIN_SECRET=
YURBRAIN_HASURA_ROLE=user
