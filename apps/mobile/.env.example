# Public-only mobile env vars (bundled into app binary/config).
# Canonical env matrix + examples:
# docs/nhost/environments.md
#
# Do NOT place server secrets here.
# No admin secrets, no server JWT signing secrets, no DB secrets.
#
# Required (mobile runtime needs anon key + addressing):
EXPO_PUBLIC_NHOST_ANON_KEY=

# Addressing mode A (preferred explicit URL):
EXPO_PUBLIC_NHOST_BACKEND_URL=

# Addressing mode B (subdomain + region; keep for compatibility/fallback):
EXPO_PUBLIC_NHOST_SUBDOMAIN=
EXPO_PUBLIC_NHOST_REGION=

# Optional explicit service URLs (derived from backend URL when unset):
EXPO_PUBLIC_NHOST_GRAPHQL_URL=
EXPO_PUBLIC_NHOST_AUTH_URL=
EXPO_PUBLIC_NHOST_STORAGE_URL=
EXPO_PUBLIC_NHOST_FUNCTIONS_URL=

# Mobile deep-link base + auth redirect URLs.
# Must be absolute URLs and must be allowlisted in Nhost dashboard.
EXPO_PUBLIC_NHOST_MOBILE_DEEP_LINK_BASE_URL=
EXPO_PUBLIC_NHOST_SIGN_IN_REDIRECT_URL=
EXPO_PUBLIC_NHOST_SIGN_OUT_REDIRECT_URL=
EXPO_PUBLIC_NHOST_PASSWORD_RESET_REDIRECT_URL=
EXPO_PUBLIC_NHOST_EMAIL_VERIFICATION_REDIRECT_URL=
